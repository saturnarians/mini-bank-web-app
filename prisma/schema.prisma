// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  email     String     @unique
  name      String
  password  String
  role      String     @default("user") // superadmin, admin, manager, user
  phone     String?
  address   String?
  emailVerified Boolean  @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  accounts     Account[]
  transactions Transaction[]
}

model Account {
  id                String        @id @default(auto()) @map("_id") @db.ObjectId
  userId            String        @db.ObjectId
  accountNumber     String        @unique
  accountType       String        // checking, savings, investment
  balance           Float         @default(0)
  currency          String        @default("USD")
  status            String        @default("active") // active, inactive, closed
  createdAt         DateTime      @default(now())
  lastTransactionAt DateTime?
  updatedAt         DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([userId])
}

model Transaction {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  accountId          String   @db.ObjectId
  userId             String   @db.ObjectId
  type               String   // deposit, withdrawal, transfer
  amount             Float
  currency           String   @default("USD")
  status             String   @default("pending") // completed, pending, failed
  description        String
  recipientAccountId String?  @db.ObjectId
  recipientName      String?
  timestamp          DateTime @default(now())
  reference          String   @unique
  updatedAt          DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([userId])
  @@index([timestamp])
}
