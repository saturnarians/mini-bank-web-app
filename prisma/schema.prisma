datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// --- Enums ---

enum AccountStatus {
  completed
  pending
  closed
  suspended
}

enum AccountType {
  checking
  savings
  investment
}

enum TransactionType {
  deposit
  withdrawal
  transfer
  adjustment
}

// --- Models ---

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  email         String    @unique
  name          String
  password      String
  role          String    @default("user")
  phone         String?
  address       String?
  emailVerified Boolean   @default(false)
  supervisorId  String?   @db.ObjectId
  status        String    @default("active")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  transactions  Transaction[]
  adminLogs     AdminActionLog[]
  
  // FIX 1: Changed onDelete/onUpdate to NoAction to satisfy Prisma Self-Relation rules
  supervisedBy  User?   @relation("SupervisorRelation", fields: [supervisorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subordinates  User[]  @relation("SupervisorRelation")

  @@index([supervisorId])
  @@index([role])
  @@index([status])
}

model AdminActionLog {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  adminId    String   @db.ObjectId
  action     String
  targetType String
  targetId   String   @db.ObjectId
  reason     String?
  metadata   Json?
  createdAt  DateTime @default(now())

  admin      User     @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([targetId])
  @@index([createdAt])
}

model Account {
  id                  String       @id @default(auto()) @map("_id") @db.ObjectId
  userId              String       @db.ObjectId
  accountNumber       String       @unique
  accountType         AccountType
  balance             Float        @default(0)
  currency            String       @default("USD")
  status              String       @default("active")
  transactionsEnabled Boolean      @default(true)
  createdAt           DateTime     @default(now())
  lastTransactionAt   DateTime?
  updatedAt           DateTime     @updatedAt

  user                User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions        Transaction[]
  logs                AccountLog[]
  snapshots           BalanceSnapshot[]

  @@index([userId])
}

model AccountLog {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  accountId   String   @db.ObjectId
  action      String
  reason      String?
  performedBy String   @db.ObjectId
  createdAt   DateTime @default(now())

  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
}

model Transaction {
  id                 String          @id @default(auto()) @map("_id") @db.ObjectId
  accountId          String          @db.ObjectId
  userId             String?         @db.ObjectId
  type               TransactionType
  reason             String?
  amount             Float
  runningBalance     Float
  currency           String          @default("USD")
  status             AccountStatus
  description        String
  recipientAccountId String?         @db.ObjectId
  recipientName      String?
  timestamp          DateTime        @default(now())
  reference          String?         @unique
  updatedAt          DateTime        @updatedAt
  metadata           Json?
  counterPartyAccountId String?

  account            Account         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  
  // FIX 2: Changed to NoAction to avoid conflict with "User -> Account -> Transaction" cascade
  user               User?           @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([accountId])
  @@index([userId])
  @@index([timestamp])
}

model BalanceSnapshot {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  accountId String   @db.ObjectId
  balance   Float
  date      DateTime
  createdAt DateTime @default(now())

  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, date])
  @@index([accountId])
  @@index([date])
}